{
  "name": "@midnightntwrk/midnight-sdk-monorepo",
  "description": "Midnight SDK monorepo — platform-js and compact-js packages",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.10.3",
  "repository": "git@github.com:midnightntwrk/midnight-sdk",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dist": "turbo run dist",
    "clean": "turbo run clean",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "eslint",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "format:root": "prettier --write --ignore-path .prettierignore.root \"**/*.{ts,js,json,yaml,yml,md}\"",
    "format:check:root": "prettier --check --ignore-path .prettierignore.root \"**/*.{ts,js,json,yaml,yml,md}\"",
    "postinstall": "husky",
    "changeset": "changeset",
    "changeset:status": "changeset status --verbose",
    "changeset:version": "changeset version && yarn install --mode=update-lockfile",
    "changeset:publish": "yarn dist && node scripts/publish.mjs && changeset tag"
  },
  "resolutions": {
    "tar": ">=7.5.11",
    "flatted": ">=3.4.2",
    "@isaacs/brace-expansion": ">=5.0.1",
    "glob": ">=13.0.1",
    "effect": "^3.21.4"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^19.0.0",
    "@effect/build-utils": "^0.8.9",
    "@effect/cluster": "^0.57.0",
    "@effect/experimental": "^0.60.0",
    "@effect/platform-node": "^0.107.0",
    "@effect/platform-node-shared": "^0.59.0",
    "@effect/rpc": "^0.75.1",
    "@effect/sql": "^0.51.1",
    "@effect/vitest": "^0.29.0",
    "@effect/workflow": "^0.17.0",
    "@eslint/js": "^10.0.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.0.0",
    "prettier": "^3.8.4",
    "shx": "^0.4.0",
    "tstyche": "^6.2.0",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
