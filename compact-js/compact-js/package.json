{
  "name": "@midnight-ntwrk/compact-js",
  "version": "2.5.5-rc.3",
  "description": "Typescript-based execution environment for smart contracts compiled with the Compact language",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "types": "./dist/dts/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./effect": "./src/effect/index.ts",
    "./effect/*": "./src/effect/*.ts",
    "./effect/internal/*": null
  },
  "dependencies": {
    "@effect/platform": "^0.96.1",
    "@midnight-ntwrk/compact-runtime": "0.17.104-dev.1dcee19f4367a5cd36b23e81fd917d58844beeb0",
    "@midnight-ntwrk/platform-js": "^3.0.0",
    "@midnightntwrk/ledger-v9": "^1.0.0-rc.3",
    "effect": "^3.21.4",
    "tslib": "^2.8.1"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/midnight-ntwrk/artifacts.git"
  },
  "packageManager": "yarn@4.10.3",
  "author": "IOHK",
  "license": "Apache-2.0",
  "scripts": {
    "build": "yarn build-compact && yarn build-esm && yarn build-cjs && build-utils pack-v3",
    "build-esm": "tsc -b tsconfig.build.json",
    "build-cjs": "tsc -b tsconfig.cjs.json",
    "build-compact": "(shx --negate test -d ./test/contract/managed && yarn compact || true)",
    "clean": "shx rm -rf ./build ./dist ./.tsbuildinfo ./reports ./coverage .tsbuildinfo",
    "test": "yarn build-compact && vitest run && tstyche",
    "package": "shx rm -rf ./dist/src && node ../scripts/resolve-workspace-protocol.mjs ./dist/package.json && (cd ./dist; npm pack)",
    "compact": "fetch-compactc && yarn compact-counter && yarn compact-unshielded",
    "compact-counter": "run-compactc ./test/contract/counter.compact ./test/contract/managed/counter",
    "compact-unshielded": "run-compactc ./test/contract/unshielded.compact ./test/contract/managed/unshielded"
  },
  "files": [
    "dist/"
  ]
}
