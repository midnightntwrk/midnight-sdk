import CompactStandardLibrary;

contract cccInner {
  circuit getV(): Field;
  circuit setV(value: Field): [];
}

export ledger inner: cccInner;

constructor(i: cccInner) {
  inner = disclose(i);
}

export circuit incrementInner(increment_amount: Field):[] {
  const current = inner.getV();
  inner.setV(current + disclose(increment_amount));
}

export circuit getInner(): Field {
  return inner.getV();
}
