{
  "name": "@midnight-ntwrk/compact-js-command",
  "version": "2.5.5-rc.7",
  "description": "Command line utilities for working with smart contracts compiled with the Compact language",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./effect": "./src/effect/index.ts",
    "./effect/*": "./src/effect/*.ts",
    "./effect/internal/*": null
  },
  "dependencies": {
    "@effect/cli": "^0.75.0",
    "@effect/cluster": "^0.57.0",
    "@effect/experimental": "^0.60.0",
    "@effect/platform": "^0.96.2",
    "@effect/platform-node": "^0.108.0",
    "@effect/platform-node-shared": "^0.59.0",
    "@effect/printer": "^0.49.0",
    "@effect/printer-ansi": "^0.49.0",
    "@effect/rpc": "^0.76.0",
    "@effect/sql": "^0.51.1",
    "@effect/typeclass": "^0.40.0",
    "@effect/workflow": "^0.19.0",
    "@midnight-ntwrk/compact-js": "workspace:^",
    "@midnight-ntwrk/compact-js-node": "workspace:^",
    "@midnight-ntwrk/compact-runtime": "0.18.0-rc.1",
    "@midnight-ntwrk/platform-js": "^3.0.0",
    "@midnight-ntwrk/wallet-sdk-address-format": "3.1.0",
    "@midnightntwrk/ledger-v9": "^1.0.0-rc.3",
    "effect": "^3.21.4",
    "json5": "^2.2.3",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/midnightntwrk/midnight-sdk.git"
  },
  "packageManager": "yarn@4.10.3",
  "author": "IOHK",
  "license": "Apache-2.0",
  "scripts": {
    "build": "yarn build-esm && build-utils pack-v3",
    "build-esm": "tsc -b tsconfig.build.json",
    "clean": "shx rm -rf ./build ./dist ./.tsbuildinfo ./reports ./coverage",
    "test": "npx vitest run",
    "cmd": "NODE_OPTIONS='--loader ts-node/esm --no-warnings' ts-node ./src/index.ts",
    "package": "shx rm -rf ./dist/src && node ../scripts/resolve-workspace-protocol.mjs ./dist/package.json && (cd ./dist; npm pack)"
  },
  "files": [
    "dist/"
  ]
}
