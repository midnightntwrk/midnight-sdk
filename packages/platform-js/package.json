{
  "name": "@midnightntwrk/platform-js",
  "version": "3.0.0",
  "description": "Provides a set of core abstractions, utilities, and types for building services and libraries that work with the Midnight blockchain",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./effect": "./src/effect/index.ts",
    "./effect/*": "./src/effect/*.ts",
    "./effect/internal/*": null
  },
  "dependencies": {
    "@effect/platform": "^0.96.1",
    "effect": "^3.21.4",
    "tslib": "^2.8.1"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/midnight-ntwrk/artifacts.git"
  },
  "engines": {
    "node": ">=22"
  },
  "author": "IOHK",
  "license": "Apache-2.0",
  "scripts": {
    "dist": "yarn build-esm && build-utils pack-v3",
    "build-esm": "tsc -b tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "clean": "shx rm -rf ./build ./dist ./.tsbuildinfo ./reports ./coverage",
    "format": "prettier --write \"**/*.{ts,js,json,yaml,yml,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,yaml,yml,md}\"",
    "test": "vitest run"
  },
  "files": [
    "dist/"
  ]
}
