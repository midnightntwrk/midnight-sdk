# Compact toolchain configuration for @midnightntwrk/compact-js.
#
# Loaded automatically by direnv (repo-root .envrc) and by CI. Consumed by the
# fetch-compactc / run-compactc binaries (from @midnight-ntwrk/midnight-js-compact)
# when building/compiling the Compact test contracts.
#
#   COMPACTC_VERSION     the compactc compiler version to download/use
#   COMPACT_TAG_PREFIX   git tag prefix on the release repo (tag = <prefix><version>)
#   COMPACT_REPO         GitHub repo to fetch compactc releases from
#   COMPACT_ASSET_PREFIX release asset filename prefix (asset = <prefix><version>...)
#
# (COMPACT_HOME, if set in your shell, points fetch/run at a pre-installed compactc.)

COMPACTC_VERSION=0.33.0-rc.0
COMPACT_TAG_PREFIX=compactc-v
COMPACT_REPO=LFDT-Minokawa/compact
COMPACT_ASSET_PREFIX=compactc_v
