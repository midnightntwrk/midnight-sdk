{
  "name": "@midnightntwrk/compact-js-command",
  "version": "2.5.5-rc.3",
  "description": "Command line utilities for working with smart contracts compiled with the Compact language",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./effect": "./src/effect/index.ts",
    "./effect/*": "./src/effect/*.ts",
    "./effect/internal/*": null
  },
  "dependencies": {
    "@effect/cli": "^0.75.0",
    "@effect/cluster": "^0.57.0",
    "@effect/experimental": "^0.60.0",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.107.0",
    "@effect/platform-node-shared": "^0.59.0",
    "@effect/printer": "^0.49.0",
    "@effect/printer-ansi": "^0.49.0",
    "@effect/rpc": "^0.75.1",
    "@effect/sql": "^0.51.1",
    "@effect/typeclass": "^0.40.0",
    "@effect/workflow": "^0.17.0",
    "@midnight-ntwrk/compact-runtime": "0.18.0-rc.0",
    "@midnight-ntwrk/wallet-sdk-address-format": "3.1.0",
    "@midnightntwrk/compact-js": "workspace:^",
    "@midnightntwrk/compact-js-node": "workspace:^",
    "@midnightntwrk/ledger-v9": "^1.0.0-rc.2",
    "@midnightntwrk/platform-js": "workspace:^",
    "effect": "^3.21.4",
    "json5": "^2.2.3",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/midnight-ntwrk/artifacts.git"
  },
  "engines": {
    "node": ">=22"
  },
  "author": "IOHK",
  "license": "Apache-2.0",
  "scripts": {
    "dist": "yarn build-esm && build-utils pack-v3",
    "build-esm": "tsc -b tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "clean": "shx rm -rf ./build ./dist ./.tsbuildinfo ./reports ./coverage",
    "format": "prettier --write \"**/*.{ts,js,json,yaml,yml,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,yaml,yml,md}\"",
    "test": "npx vitest run",
    "cmd": "NODE_OPTIONS='--loader ts-node/esm --no-warnings' ts-node ./src/index.ts"
  },
  "files": [
    "dist/"
  ]
}
